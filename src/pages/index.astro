---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPosts = posts.slice(0, 2);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-white">
		<Header />
		<main class="pt-32 pb-20 px-6">
			<section class="max-w-5xl mx-auto">
				<!-- Hero Section -->
				<div class="text-center mb-32 group">
					<span class="text-[10px] font-bold tracking-[0.4em] text-black/20 uppercase mb-6 block transform group-hover:translate-y-[-4px] transition-transform duration-700">Willkommen bei Activecenter</span>
					<h1 class="text-7xl md:text-9xl font-bold tracking-tighter mb-10 leading-[0.85]">
						Upgrade <br class="hidden md:block" /> <span class="text-black/10">Yourself.</span>
					</h1>
					<p class="text-xl md:text-3xl text-gray-400 font-light max-w-2xl mx-auto leading-relaxed">
						Ein Journal über Lebensenergie, Unabhängigkeit und das Design eines außergewöhnlichen Alltags.
					</p>
				</div>

				<!-- Featured Grid -->
				<div class="grid grid-cols-1 md:grid-cols-2 gap-16 mb-32">
					{featuredPosts.map((post, index) => (
						<a href={`/blog/${post.id}/`} class={`group block ${index === 1 ? 'md:mt-32' : ''}`}>
							<div class="aspect-[16/10] rounded-[40px] overflow-hidden mb-8 border border-black/5 shadow-sm group-hover:shadow-2xl transition-all duration-1000">
								{post.data.heroImage && (
									<img src={post.data.heroImage} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" />
								)}
							</div>
							<div class="px-4 text-center md:text-left">
								<span class="text-[10px] font-bold tracking-[0.2em] text-black/30 md:text-black/40 uppercase mb-4 block underline decoration-black/5 underline-offset-8">Highlight</span>
								<h2 class="text-3xl md:text-4xl font-bold group-hover:text-black/60 transition-colors leading-tight">
									{post.data.title}
								</h2>
								<p class="text-gray-400 mt-6 font-light leading-relaxed text-lg line-clamp-2">
									{post.data.description}
								</p>
							</div>
						</a>
					))}
				</div>

				<!-- CTA Card -->
				<div class="content-card p-16 md:p-32 text-center relative overflow-hidden group">
					<div class="relative z-10">
						<h2 class="text-5xl md:text-7xl font-bold mb-8 tracking-tighter leading-none">Werde Teil der <br/> Community.</h2>
						<p class="text-xl text-gray-400 mb-12 max-w-md mx-auto font-light">Exklusive Einblicke in den Fit-Marathon und Strategien für deinen Erfolg.</p>
						<button class="bg-black text-white px-12 py-5 rounded-full font-bold hover:scale-105 active:scale-95 transition-all text-xs tracking-widest uppercase">
							Jetzt Newsletter abonnieren
						</button>
					</div>
					<div class="absolute inset-0 bg-gradient-to-tr from-gray-50 to-white -z-0"></div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
