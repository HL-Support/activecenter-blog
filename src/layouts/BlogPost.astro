---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style is:global>
			/* Direct Premium Typography (Brute Force Spacing) */
			.journal-content {
				color: #374151;
				line-height: 2;
				font-size: 1.125rem;
				font-weight: 300;
			}
			.journal-content h2 {
				font-family: 'Outfit', sans-serif;
				font-weight: 700;
				color: #000;
				font-size: 2.5rem;
				letter-spacing: -0.05em;
				margin-top: 6rem !important;
				margin-bottom: 2.5rem !important;
				line-height: 1.1;
			}
			.journal-content h3 {
				font-family: 'Outfit', sans-serif;
				font-weight: 700;
				color: #000;
				font-size: 1.75rem;
				margin-top: 4rem !important;
				margin-bottom: 1.5rem !important;
			}
			.journal-content p {
				margin-bottom: 3rem !important;
			}
			.journal-content strong {
				font-weight: 600;
				color: #000;
			}
			.journal-content ul {
				list-style: none;
				padding: 0;
				margin-bottom: 4rem !important;
				margin-top: 2rem !important;
			}
			.journal-content ul li {
				position: relative;
				padding-left: 2.5rem;
				margin-bottom: 2.5rem !important;
				line-height: 1.8;
			}
			.journal-content ul li::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0.8em;
				width: 1.25rem;
				height: 1px;
				background-color: rgba(0,0,0,0.1);
			}
			.journal-content hr {
				border: none;
				height: 1px;
				background-color: rgba(0,0,0,0.05);
				margin: 6rem 0 !important;
			}
		</style>
	</head>

	<body class="bg-white">
		<Header />
		<main class="pt-32 pb-40 px-6">
			<article class="max-w-5xl mx-auto">
				<!-- Header Area -->
				<header class="max-w-3xl mx-auto text-center mb-24">
					<div class="mb-6 flex justify-center items-center gap-4">
						<span class="text-[10px] font-bold tracking-[0.4em] text-black/20 uppercase">Strategy & Freedom</span>
						<span class="w-1 h-1 rounded-full bg-black/10"></span>
						<span class="text-[10px] font-bold tracking-[0.2em] text-black/40 uppercase">
							<FormattedDate date={pubDate} />
						</span>
					</div>
					<h1 class="text-5xl md:text-7xl font-bold mb-10 tracking-tighter leading-[0.9]">{title}</h1>
					<p class="text-xl md:text-2xl text-gray-400 max-w-2xl mx-auto font-light leading-relaxed">{description}</p>
				</header>

				<!-- Hero Image Full Width -->
				<div class="max-w-5xl mx-auto mb-32 -mx-4 md:mx-auto">
					{heroImage && <img width={1200} height={600} src={heroImage} alt="" class="rounded-[40px] shadow-2xl border border-black/5 aspect-[16/7] object-cover hover:scale-[1.01] transition-transform duration-1000" />}
				</div>

				<!-- Content Column -->
				<div class="max-w-2xl mx-auto journal-content">
					<slot />
				</div>
				
				<!-- Article Footer -->
				<footer class="max-w-2xl mx-auto mt-40 pt-20 border-t border-black/5 text-center">
					<div class="flex flex-col items-center">
						<div class="w-16 h-16 rounded-full bg-gray-100 mb-6 overflow-hidden grayscale">
							<img src="https://avatars.githubusercontent.com/u/1?v=4" alt="Markus">
						</div>
						<div class="text-xs font-bold uppercase tracking-widest text-black">Markus Oberhofer</div>
						<div class="text-gray-400 text-sm mt-2 font-light italic leading-loose max-w-sm">
							"Upgrade Yourself" ist die gelebte Philosophie, das eigene Leben nach den Prinzipien wissenschaftlicher Exzellenz und persönlicher Freiheit zu gestalten.
						</div>
					</div>
				</footer>
			</article>
		</main>
		<Footer />
	</body>
</html>
