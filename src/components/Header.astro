---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="glass-nav px-6">
	<nav class="max-w-5xl mx-auto h-16 flex items-center justify-between">
		<div class="flex items-center space-x-2">
			<a href="/" class="text-xl font-bold tracking-tighter text-black uppercase hover:opacity-70 transition-opacity">Activecenter</a>
			<span class="text-[10px] bg-black text-white px-2 py-0.5 rounded-full font-bold tracking-widest">BLOG</span>
		</div>
		<div class="hidden md:flex space-x-8 text-sm font-medium">
			<HeaderLink href="/" class="premium-link">Start</HeaderLink>
			<HeaderLink href="/blog" class="premium-link">Journal</HeaderLink>
			<HeaderLink href="/about" class="premium-link">About</HeaderLink>
		</div>
		<div class="flex items-center space-x-4">
			<button class="hidden sm:block bg-black text-white text-[10px] font-bold px-4 py-2 rounded-full hover:bg-black/80 transition-all uppercase tracking-widest">
				Upgrade Yourself
			</button>
		</div>
	</nav>
</header>
