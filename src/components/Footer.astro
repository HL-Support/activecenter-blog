---
const today = new Date();
---

<footer class="py-20 bg-white border-t border-gray-100 text-center">
	<div class="max-w-5xl mx-auto px-6">
		<div class="text-sm font-bold tracking-tighter mb-8 italic uppercase text-black/20">Upgrade Yourself</div>
		<p class="text-[10px] text-gray-400 font-medium uppercase tracking-[0.2em] mb-4">
			&copy; {today.getFullYear()} Activecenter. All rights reserved.
		</p>
		<div class="flex flex-wrap justify-center gap-8 text-[10px] text-gray-400 font-bold uppercase tracking-widest">
			<a href="/impressum" class="hover:text-black transition-colors">Impressum</a>
			<a href="/datenschutz" class="hover:text-black transition-colors">Datenschutz</a>
			<a href="/kontakt" class="hover:text-black transition-colors">Kontakt</a>
		</div>
	</div>
</footer>
